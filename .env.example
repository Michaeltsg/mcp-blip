# ----------------------------------------------------------------------------
# blip-mcp configuration. Copy to ".env" and fill in. NEVER commit your .env.
# ----------------------------------------------------------------------------

# --- Credentials (choose ONE of the two modes) ------------------------------

# Mode 1 (PREFERRED): the ready-made header value copied from the Blip portal at
#   Configurações -> Informações de conexão -> HTTP Endpoints
#   -> "Cabeçalho de autenticação (Authorization)".
# It already looks like "Key <base64(identity:key)>". Paste it verbatim.
BLIP_AUTHORIZATION="Key eyJ...your-key..."

# Mode 2: bot identifier + access key. The server computes
#   Authorization: Key base64("<identifier>:<accessKey>")
# Leave BLIP_AUTHORIZATION empty if you use this mode.
# BLIP_BOT_IDENTIFIER="mybot"
# BLIP_ACCESS_KEY="abc123..."

# --- Host -------------------------------------------------------------------

# Your contract / bot shortname = the host subdomain.
# Host becomes https://<contract>.http.msging.net
# If omitted, falls back to https://http.msging.net (accounts not in an org).
BLIP_CONTRACT_ID="my-contract"
# BLIP_SHORTNAME="my-contract"   # alias for BLIP_CONTRACT_ID
# BLIP_BASE_URL="https://my-contract.http.msging.net"  # full override (rare)

# --- Safety -----------------------------------------------------------------

# Master switch for every tool that sends messages or mutates data.
# Default false => write tools refuse and return a read-only notice.
BLIP_ALLOW_WRITES="false"

# --- Tuning (optional) ------------------------------------------------------

# BLIP_REQUEST_TIMEOUT_MS="30000"
# BLIP_MAX_RETRIES="3"
# BLIP_LOG_LEVEL="info"   # error | warn | info | debug
